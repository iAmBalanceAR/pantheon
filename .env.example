# ============================================================
# Pantheon — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# cp .env.example .env.local
# ============================================================


# ── Supabase ─────────────────────────────────────────────────
# Create a free project at https://supabase.com
# Find these in: Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ── LLM Providers ────────────────────────────────────────────
# You need at least ONE of Fireworks or Gemini to run agents.
# Anthropic is optional (not used by default in v0.9).

# Fireworks AI — https://fireworks.ai (used for coder/banker/researcher agents)
# Free tier available. Fast and affordable for Llama models.
FIREWORKS_API_KEY=fw_your_key_here

# Google Gemini — https://aistudio.google.com/apikey (used for controller/auditor agents)
# Free tier available. Required for the Controller agent by default.
GOOGLE_API_KEY=AIza_your_key_here

# Anthropic — https://console.anthropic.com (optional, not used by default)
ANTHROPIC_API_KEY=sk-ant-your_key_here


# ── Agent Model Assignments ───────────────────────────────────
# These are the platform defaults. You can override per-project.
# Remove any of these lines to use the built-in code defaults.

# Controller — analyzes specs, plans teams, orchestrates sprints
CONTROLLER_PROVIDER=gemini
CONTROLLER_MODEL=gemini-2.5-flash

# Auditor — reviews sprint output, enforces quality gates
AUDITOR_PROVIDER=gemini
AUDITOR_MODEL=gemini-2.5-flash

# Coder — default model for all coding/writing agents
CODER_PROVIDER=fireworks
CODER_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# Banker — monitors token and dollar usage (lightweight task)
BANKER_PROVIDER=fireworks
BANKER_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct


# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
